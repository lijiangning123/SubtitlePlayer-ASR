      }
    },
    "custom_openai_compatible": {
      "provider": "custom",
      "apiKey": "your-api-key",
      "model": "your-model",
      "baseUrl": "https://your-openai-compatible-endpoint/v1",
      "apiType": "chat_completions"
    }
