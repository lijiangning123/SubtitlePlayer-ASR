{
  "provider": "openai",
  "openai": {
    "apiKey": "sk-your-openai-key",
    "model": "gpt-5.2"
  },
  "_examples": {
    "qwen": {
      "provider": "qwen",
      "qwen": {
        "apiKey": "sk-your-dashscope-key",
        "model": "qwen-plus",
        "baseUrl": "https://dashscope.aliyuncs.com/compatible-mode/v1"
      }
    },
    "doubao": {
      "provider": "doubao",
      "doubao": {
        "apiKey": "your-volcengine-ark-key",
        "model": "your-doubao-or-ark-model-id",
